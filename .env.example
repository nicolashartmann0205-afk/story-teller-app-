# Copy to .env.local and fill in values (never commit .env.local).

# Supabase (public — safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# App URL (production: https://storyinthemaking.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database — use Supabase Connect → Transaction pooler (port 6543) for serverless
POOLING_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Optional direct/session URL (migrations, local CLI fallback)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Google AI — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Optional — push .env.local secrets to Vercel: pnpm db:sync-env-vercel --deploy
# VERCEL_TOKEN=
# VERCEL_PROJECT_NAME=story-teller-app-

# Optional
BLOG_ADMIN_USER_IDS=
# AUTH_DEBUG=1
